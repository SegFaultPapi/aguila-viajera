# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignorar TODO (incluye .env.local con claves privadas), salvo ejemplos
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# contratos / Hardhat — el subdirectorio contracts/ tiene su propio .gitignore;
# estas entradas cubren por si se ejecuta hardhat desde la raíz
contracts/artifacts/
contracts/cache/
contracts/dist/
contracts/typechain-types/
