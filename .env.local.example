# ── Chatbot IA (Claude / Anthropic) ──────────────────────
# Sin clave: modo mock (respuestas predefinidas) para el prototipo
# Con clave: llama a claude-sonnet-4-5 en tiempo real
# Obtén tu clave en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Privy ────────────────────────────────────────────────
# Obtén tu App ID en: https://dashboard.privy.io → Settings → Basics
NEXT_PUBLIC_PRIVY_APP_ID=clxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Client ID si usas app clients por entorno
# NEXT_PUBLIC_PRIVY_CLIENT_ID=

# ── Entorno ───────────────────────────────────────────────
# "prototype" = mock OTP (sin Privy real) | "production" = Privy SMS real
# Si no defines NEXT_PUBLIC_PRIVY_APP_ID se cae automáticamente a prototype
NEXT_PUBLIC_APP_ENV=prototype

# ── Blockchain / DocumentRegistry ────────────────────────
# Red activa: "sepolia" (testnet, default) o "mainnet" (producción)
NEXT_PUBLIC_BLOCKCHAIN_RED=sepolia

# Dirección del contrato DocumentRegistry desplegado
# Se genera corriendo: cd contracts && npm run deploy:sepolia
NEXT_PUBLIC_DOCUMENT_REGISTRY_SEPOLIA=0x...
NEXT_PUBLIC_DOCUMENT_REGISTRY_MAINNET=0x...
# Solo necesario en desarrollo local con `hardhat node`
NEXT_PUBLIC_DOCUMENT_REGISTRY_LOCAL=0x...

# Alchemy API Key para leer la blockchain desde el frontend (verificación pública)
# https://alchemy.com → Create App → Ethereum → Sepolia
# Sin esta key se usa el RPC público de Ankr (límite de rate más bajo)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Clave privada de la wallet institucional que PUBLICA las actas (servidor).
# SIN prefijo NEXT_PUBLIC_ — nunca debe llegar al navegador. El coordinador
# nunca ve ni firma nada: el backend firma con esta clave cuando el
# coordinador presiona "Publicar acta en Ethereum".
# Debe coincidir con la dirección configurada abajo en COPACO_PUBLICADOR_ADDRESS.
COPACO_PUBLICADOR_PRIVATE_KEY=

# (Opcional) Alchemy API Key del lado del servidor para firmar transacciones.
# Si no se define, se reutiliza NEXT_PUBLIC_ALCHEMY_API_KEY.
ALCHEMY_API_KEY=

# ── Solo para desplegar el contrato (cd contracts && npm run deploy:sepolia) ──
# Un solo .env.local para todo el proyecto — Hardhat también lee este archivo
# (ver contracts/hardhat.config.ts). Estas dos variables no se usan en runtime,
# solo durante el deploy.

# Clave privada de la wallet que paga el gas del deploy (una sola vez).
# NUNCA usar una wallet de mainnet — usar una cuenta de testnet separada.
COPACO_DEPLOYER_PRIVATE_KEY=0x...

# Dirección de la wallet publicadora (la de COPACO_PUBLICADOR_PRIVATE_KEY de
# arriba). Se pasa al constructor del contrato como la única autorizada a
# llamar publicarActa(). Si se deja vacío, el deployer también es el publicador
# (solo recomendable en localhost/testnet).
COPACO_PUBLICADOR_ADDRESS=

# Etherscan API Key — para verificar el contrato públicamente después del deploy
# https://etherscan.io/apis
ETHERSCAN_API_KEY=
