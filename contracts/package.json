{
  "name": "aguila-viajera-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Smart contracts para Águila Viajera / COPACO — DocumentRegistry en Ethereum",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mainnet",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "node": "hardhat node",
    "verify": "hardhat verify --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.0.0",
    "dotenv": "^17.4.2",
    "hardhat": "^2.22.0",
    "typescript": "^5.0.0"
  }
}
