# Clave privada de la wallet desplegadora / wallet institucional COPACO
# NUNCA usar la wallet de mainnet para pruebas — usar una cuenta de testnet separada
# En producción: usar Gnosis Safe multisig como coordinador institucional
COPACO_DEPLOYER_PRIVATE_KEY=0x...

# Alchemy API Key (https://alchemy.com) — para conectar a Sepolia y Mainnet
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Etherscan API Key — para verificar el contrato en Etherscan después del deploy
ETHERSCAN_API_KEY=your_etherscan_api_key_here
